# Terminal Services Configuration
# Copy to services.yaml and customize
#
# Format:
#   services:
#     - name:
#         repo: repository URL (required)
#         path: local path (optional, defaults to services/name)
#         metarepo: true if this is a metarepo with services/ subdirectory

services:
  # Core terminal emulator
  - terminal:
      repo: git@github.com:omnidotdev/terminal#master

  # Website
  - terminal-site:
      repo: git@github.com:omnidotdev/terminal-site#master
